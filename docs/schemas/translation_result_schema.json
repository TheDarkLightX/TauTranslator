{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TauTranslatorOmega Plugin Translation Result",
  "description": "JSON Schema for the output produced by a TauTranslatorOmega plugin.",
  "type": "object",
  "properties": {
    "status": {
      "description": "Indicates the outcome of the translation.",
      "type": "string",
      "enum": ["success", "error"]
    },
    "data": {
      "description": "Contains the successful translation output and any warnings. Present if status is \"success\".",
      "type": "object",
      "properties": {
        "translated_text": {
          "description": "The translated output as a string.",
          "type": "string"
        },
        "output_metadata": {
          "description": "Optional: Additional metadata about the translated output (e.g., specific grammar version used, dialect information).",
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "warnings": {
          "description": "Optional: An array of warning messages.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/WarningMessage"
          },
          "default": []
        }
      },
      "required": [
        "translated_text"
      ],
      "additionalProperties": false
    },
    "error": {
      "description": "Contains error details. Present if status is \"error\".",
      "type": "object",
      "properties": {
        "code": {
          "description": "Plugin-specific error code.",
          "type": ["string", "null"]
        },
        "message": {
          "description": "Human-readable error message.",
          "type": "string"
        },
        "details": {
          "description": "Optional: Further technical details or stack trace snippet.",
          "type": ["string", "null"]
        },
        "ilr_path": {
          "description": "Optional: JSONPath to the problematic ILR node (e.g., \"$.statements[2].condition\").",
          "type": ["string", "null"]
        }
      },
      "required": [
        "message"
      ],
      "additionalProperties": false
    }
  },
  "required": ["status"],
  "additionalProperties": false,
  "if": {
    "properties": { "status": { "const": "success" } }
  },
  "then": {
    "required": ["status", "data"]
  },
  "else": {
    "if": {
      "properties": { "status": { "const": "error" } }
    },
    "then": {
      "required": ["status", "error"]
    }
  },
  "definitions": {
    "WarningMessage": {
      "type": "object",
      "properties": {
        "code": {
          "description": "Plugin-specific warning code.",
          "type": ["string", "null"]
        },
        "message": {
          "description": "Human-readable warning message.",
          "type": "string"
        },
        "ilr_path": {
          "description": "Optional: JSONPath to the ILR node related to the warning.",
          "type": ["string", "null"]
        }
      },
      "required": ["message"],
      "additionalProperties": false
    }
  }
}
