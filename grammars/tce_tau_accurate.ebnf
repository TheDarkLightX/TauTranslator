# TCE (Tau Controlled English) Accurate Grammar
# Based on IDNI Tau Language parser/tau.tgf and real-world demos
# 
# Design Principles:
# 1. Natural language feel with precise Tau semantics
# 2. Direct 1:1 mapping to Tau Language constructs (WFF, BF, REF)
# 3. Support for stream I/O system with temporal logic
# 4. Recurrence relations and function definitions
# 5. CLI command integration for solver capabilities
# 6. Compatible with LLM generation (transformers-CFG, Guidance)

# Root rule - TCE program structure (maps to Tau: rr _ wff:main _ '.')
tce_program = [recurrence_relations] main_formula "." ;

# Recurrence relations (maps to Tau: rec_relations)
recurrence_relations = (recurrence_relation ".")* ;

recurrence_relation = function_definition
                    | stream_definition
                    | rule_definition ;

# Main formula (maps to Tau: wff:main)
main_formula = wff_expression ;

# === WFF (Well-Formed Formulas) - Logical Expressions ===

wff_expression = wff_conditional
               | wff_implication
               | wff_equivalence
               | wff_disjunction ;

wff_conditional = wff_disjunction "?" wff_disjunction ":" wff_disjunction ;

wff_implication = wff_equivalence ("implies" | "->") wff_equivalence
                | wff_equivalence ("is implied by" | "<-") wff_equivalence ;

wff_equivalence = wff_disjunction ("if and only if" | "<->") wff_disjunction ;

wff_disjunction = wff_conjunction ("or" | "||") wff_conjunction ;

wff_conjunction = wff_xor ("and" | "&&") wff_xor ;

wff_xor = wff_negation ("xor" | "^") wff_negation ;

wff_negation = ("not" | "!") wff_primary
             | wff_primary ;

wff_primary = "(" wff_expression ")"
            | temporal_quantifier
            | quantified_expression
            | relational_expression
            | constraint_expression
            | capture_variable
            | "true" | "T"
            | "false" | "F" ;

# === Temporal Logic (maps to Tau: always, sometimes) ===

temporal_quantifier = ("always" | "[]") wff_expression
                    | ("sometimes" | "<>") wff_expression ;

# === Quantified Expressions (maps to Tau: all, ex) ===

quantified_expression = ("for all" | "all") variable_list "," wff_expression
                       | ("there exists" | "ex") variable_list "," wff_expression ;

variable_list = variable ("," variable)* ;

# === Relational Expressions (maps to Tau: bf comparisons) ===

relational_expression = bf_expression relational_operator bf_expression
                      | bf_expression "between" bf_expression "and" bf_expression ;

relational_operator = "equals" | "="
                    | "not equals" | "!="
                    | "less than" | "<"
                    | "greater than" | ">"
                    | "less than or equal" | "<="
                    | "greater than or equal" | ">=" ;

# === BF (Boolean Functions) - Boolean Algebra ===

bf_expression = bf_disjunction ;

bf_disjunction = bf_xor ("union" | "|") bf_xor ;

bf_xor = bf_conjunction ("xor" | "+") bf_conjunction ;

bf_conjunction = bf_complement ("intersection" | "&" | "and") bf_complement
               | bf_complement bf_complement ;  # Concatenation without operator

bf_complement = bf_primary "complement" | bf_primary "'"
              | bf_primary ;

bf_primary = "(" bf_expression ")"
           | bf_constant
           | splitter_function
           | function_reference
           | stream_reference
           | variable
           | capture_variable
           | "1" [":" type_annotation]
           | "0" [":" type_annotation] ;

# === Stream I/O System (maps to Tau: sbf, i1[t], o1[t]) ===

stream_definition = stream_type variable "=" stream_source ;

stream_type = "sbf" | "stream" | "boolean function" ;

stream_source = input_stream | output_stream ;

input_stream = ("input file" | "ifile") "(" string_literal ")"
             | "console input" ;

output_stream = ("output file" | "ofile") "(" string_literal ")"
              | "console output" ;

stream_reference = variable "[" temporal_offset "]"
                 | variable ;

temporal_offset = "t" [offset_expression]
                | "now" [offset_expression]
                | integer ;

offset_expression = ("+" | "-") integer ;

# === Function Definitions (maps to Tau: ref := ...) ===

function_definition = function_name "(" parameter_list ")" ":=" function_body
                    | function_name "[" recurrence_index "]" "(" parameter_list ")" ":=" function_body ;

function_name = identifier ;

parameter_list = [parameter ("," parameter)*] ;

parameter = variable ;

function_body = wff_expression | bf_expression ;

recurrence_index = integer | variable | variable offset_expression ;

# === Rule Definitions (maps to Tau: r o1[t] = ...) ===

rule_definition = ("rule" | "r") stream_reference "=" (wff_expression | bf_expression) ;

# === Function References (maps to Tau: ref calls) ===

function_reference = function_name "(" argument_list ")"
                   | function_name "[" temporal_offset "]" "(" argument_list ")" ;

argument_list = [argument ("," argument)*] ;

argument = wff_expression | bf_expression | variable ;

# === Special Functions ===

splitter_function = ("splitter" | "S") "(" bf_expression ")" ;

# === Constraint Expressions (maps to Tau: [ctnvar op num]) ===

constraint_expression = "[" constraint_condition "]" ;

constraint_condition = variable constraint_operator integer
                     | integer constraint_operator variable ;

constraint_operator = "!=" | "=" | ">=" | ">" | "<=" | "<" ;

# === Constants and Literals ===

bf_constant = "{" constant_binding [":" type_annotation] "}" ;

constant_binding = capture_variable | source_binding ;

source_binding = source_content ;

source_content = /[^{}]+/ ;  # Content between braces

# === Bitvector System (from bitvector.tgf) ===

bitvector_literal = unsigned_int | signed_int | unsigned_long | signed_long | bit_sequence ;

unsigned_int = ["+"] integer "u" ;

signed_int = sign integer ;

unsigned_long = ["+"] integer "ul" ;

signed_long = sign integer "l" ;

bit_sequence = bit_string "b" ;

bit_string = bit_digit (bit_digit)* ;

bit_digit = "0" | "1" ;

sign = "+" | "-" ;

# === Stream Boolean Function System (from sbf.tgf) ===

sbf_expression = sbf_disjunction ;

sbf_disjunction = sbf_xor (("union" | "|") sbf_xor)* ;

sbf_xor = sbf_conjunction (("exclusive or" | "xor" | "^" | "+") sbf_conjunction)* ;

sbf_conjunction = sbf_negation (("intersection" | "&" | "and") sbf_negation)*
                | sbf_negation sbf_negation ;  # Implicit conjunction

sbf_negation = sbf_primary ("complement" | "'")
             | sbf_primary ;

sbf_primary = "(" sbf_expression ")"
            | variable
            | "1"
            | "0" ;

# === Enhanced Type System ===

bitvector_type = "unsigned int" | "signed int" | "unsigned long" | "signed long" | "bit sequence" ;

type_annotation = bitvector_type | identifier ;

# === Variables and Captures ===

variable = io_variable | regular_variable | uninterpreted_constant ;

io_variable = input_variable | output_variable ;

input_variable = ("i" | "input") integer "[" temporal_offset "]" ;

output_variable = ("o" | "output") integer "[" temporal_offset "]"
                | ("u" | "update") "[" temporal_offset "]" ;

regular_variable = /[a-z][a-zA-Z0-9_]*/ ;

capture_variable = "$" identifier ;

uninterpreted_constant = "<" identifier ":" identifier ">" ;

# === CLI Commands (maps to Tau CLI) ===

cli_command = satisfiability_command
            | solve_command
            | normalize_command
            | normal_form_command
            | quantifier_elimination_command
            | substitution_command
            | instantiation_command ;

satisfiability_command = ("check satisfiability of" | "sat") wff_expression
                        | ("check validity of" | "valid") wff_expression
                        | ("check unsatisfiability of" | "unsat") wff_expression ;

solve_command = ("solve" | "find solution to") wff_expression ;

normalize_command = ("normalize" | "simplify") (wff_expression | bf_expression) ;

normal_form_command = normal_form_type (wff_expression | bf_expression) ;

normal_form_type = "disjunctive normal form" | "dnf"
                 | "conjunctive normal form" | "cnf"
                 | "negation normal form" | "nnf"
                 | "minterm normal form" | "mnf"
                 | "strong normal form" | "snf" ;

quantifier_elimination_command = ("eliminate quantifiers from" | "qelim") wff_expression ;

substitution_command = ("substitute" | "subst") (wff_expression | bf_expression) 
                      "[" (wff_expression | bf_expression) "/" (wff_expression | bf_expression) "]" ;

instantiation_command = ("instantiate" | "inst") (wff_expression | bf_expression)
                       "[" variable "/" bf_expression "]" ;

# === Meta Information (tau-genesis inspired) ===

meta_statement = "meta" ":" meta_field_list ;

meta_field_list = meta_field ("," meta_field)* ;

meta_field = meta_key ":" meta_value ;

meta_key = "provides" | "requires" | "version" | "author" | "description" | "complexity" ;

meta_value = string_literal | list_literal | identifier ;

list_literal = "[" [identifier ("," identifier)*] "]" ;

# === Concept Declarations (tau-genesis inspired) ===

concept_declaration = "declare concept" string_literal ["as" ":" natural_language_description] ;

natural_language_description = /[^.]+/ ;  # Free text until period

# === Type System ===

type_annotation = identifier ;

# === Terminals ===

identifier = /[a-zA-Z][a-zA-Z0-9_]*/ ;
integer = /[+-]?[0-9]+/ ;
string_literal = /"[^"]*"/ ;

# === Comments ===
# Single line: # comment
# Multi-line: /* comment */
