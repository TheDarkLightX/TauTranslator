true_val():=T
false_val():=F
ha_s(a,b):=a+b
ha_c(a,b):=a&b
fa_s(a,b,cin):=(a+b)+cin
fa_c(a,b,cin):=(a&b)|(cin&(a+b))
reserve_a_t0[0]():=F
reserve_a_t0[1]():=T
reserve_b_t0[0]():=T
reserve_b_t0[1]():=T
p0():=reserve_a_t0[0]()&reserve_b_t0[0]()
c1():=ha_c(reserve_a_t0[1]()&reserve_b_t0[0](),reserve_a_t0[0]()&reserve_b_t0[1]())
p1():=ha_s(reserve_a_t0[1]()&reserve_b_t0[0](),reserve_a_t0[0]()&reserve_b_t0[1]())
c2():=fa_c(reserve_a_t0[1]()&reserve_b_t0[1](),c1(),false_val())
p2():=fa_s(reserve_a_t0[1]()&reserve_b_t0[1](),c1(),false_val())
p3():=c2()
k_t0[0]():=p0()
k_t0[1]():=p1()
k_t0[2]():=p2()
k_t0[3]():=p3()
input_a[0]():=T
input_a[1]():=F
reserve_a_t1[0]():=fa_s(reserve_a_t0[0](),input_a[0](),false_val())
carry_a():=fa_c(reserve_a_t0[0](),input_a[0](),false_val())
reserve_a_t1[1]():=fa_s(reserve_a_t0[1](),input_a[1](),carry_a())
reserve_b_t1[0]():=F
reserve_b_t1[1]():=T
p0_t1():=reserve_a_t1[0]()&reserve_b_t1[0]()
c1_t1():=ha_c(reserve_a_t1[1]()&reserve_b_t1[0](),reserve_a_t1[0]()&reserve_b_t1[1]())
p1_t1():=ha_s(reserve_a_t1[1]()&reserve_b_t1[0](),reserve_a_t1[0]()&reserve_b_t1[1]())
c2_t1():=fa_c(reserve_a_t1[1]()&reserve_b_t1[1](),c1_t1(),false_val())
p2_t1():=fa_s(reserve_a_t1[1]()&reserve_b_t1[1](),c1_t1(),false_val())
p3_t1():=c2_t1()
k_t1[0]():=p0_t1()
k_t1[1]():=p1_t1()
k_t1[2]():=p2_t1()
k_t1[3]():=p3_t1()
equals_k0():=(k_t0[0]()'&k_t1[0]()')|(k_t0[0]()&k_t1[0]())
equals_k1():=(k_t0[1]()'&k_t1[1]()')|(k_t0[1]()&k_t1[1]())
equals_k2():=(k_t0[2]()'&k_t1[2]()')|(k_t0[2]()&k_t1[2]())
equals_k3():=(k_t0[3]()'&k_t1[3]()')|(k_t0[3]()&k_t1[3]())
invariant_holds():=equals_k0()&equals_k1()&equals_k2()&equals_k3()
solve invariant_holds()
