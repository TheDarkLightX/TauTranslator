# TauTranslator Environment Configuration
# SECURITY: Copy to .env and NEVER commit .env to version control

# API Keys (encrypted in production)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Security Settings
JWT_SECRET_KEY=change-this-to-random-64-char-string
ENCRYPTION_KEY=change-this-to-32-byte-key
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Session Configuration
SESSION_LIFETIME_MINUTES=30
MAX_SESSION_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
SECURITY_LOG_FILE=logs/security.log

# Performance Budgets
MAX_RESPONSE_TIME_MS=200
MAX_MEMORY_PER_REQUEST_MB=100
MAX_CPU_PERCENT=70

# Feature Flags
ENABLE_LMQL=false
ENABLE_GUIDANCE=false
ENABLE_TRANSFORMERS=false
ENABLE_PATTERN_FALLBACK=true

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=9090
ENABLE_TRACING=true