// Tau Controlled English (TCE) - Declarative Grammar
// Version 2.0.0 - Pure declarative specification language
// Based on Tau language's declarative paradigm
// Copyright: DarkLightX / Dana Edwards
//
// Design Principles:
// 1. All statements declare facts, properties, or relationships
// 2. No imperative commands or procedures
// 3. Temporal properties declare invariants over time
// 4. Constraints express what must be true, not what to do

?start: specification

specification: declaration+

declaration: (statement | property_declaration | constraint | temporal_property | definition) PERIOD

// Core declarative statement types
statement: logical_expr

// Facts - Simple assertions about the world
fact: concept IS concept -> is_a_fact
    | term EQUALS term -> equals_fact
    | term comparison_op term -> comparison_fact
    | function_call
    | relationship

// Property declarations - What properties entities have
property_declaration: quantified_property
                    | conditional_property
                    | compound_property_declaration

conditional_property: IF constraint_expr THEN property_declaration
compound_property_declaration: property_declaration (AND | OR) property_declaration

quantified_property: quantifier name (MUST HAVE | ARE | IS) concept
property_clause: IS concept
               | HAS concept  
               | satisfies_constraint

satisfies_constraint: SATISFIES constraint_expr
                    | SUCH_THAT constraint_expr

// Relationships - How entities relate to each other
relationship: concept relation concept -> generic_relationship
            | quantified_relationship

quantified_relationship: quantifier name relation_clause

relation_clause: relation name
               | THAT relation name  // for clarity

relation: HAS | OWNS | CONTAINS | INCLUDES | PRECEDES | FOLLOWS 
        | DEPENDS_ON | RELATES_TO | EQUALS | verb_phrase

// Constraints - What must always be true
constraint: constraint_expr HOLDS
          | IT_IS_NECESSARY_THAT constraint_expr
          | CONSTRAINT COLON constraint_expr

constraint_expr: logical_expr
               | FOR_ALL name COMMA constraint_expr
               | THERE_EXISTS name SUCH_THAT constraint_expr

// Temporal properties - Properties over time
temporal_property: temporal_quantifier property_over_time

temporal_quantifier: ALWAYS | EVENTUALLY | SOMETIMES | NEVER
                   | AT_ALL_TIMES | AT_SOME_TIME

property_over_time: stream_property
                  | state_property
                  | transition_property

stream_property: stream_term EQUALS term
               | stream_term SATISFIES constraint_expr

entity_state: concept (IS | IN) concept

state_property: entity_state concept
              | entity_state relation entity_state

condition: logical_expr
consequence: statement

transition_property: WHEN condition COMMA consequence HOLDS
                   | IF condition THEN consequence IS_TRUE

// Definitions - Declaring meaning
definition: name IS_DEFINED_AS definition_body
          | name MEANS definition_body
          | concept IS_EQUIVALENT_TO term

definition_body: term
               | set_comprehension
               | logical_combination

set_comprehension: LBRACE name SUCH_THAT logical_expr RBRACE
logical_combination: logical_expr



// Quantifiers for declarative statements
quantifier: ALL | EVERY | EACH | NO | SOME | EXACTLY number

// Concepts - A unified rule for entities and properties
concept: determiner? name name?
       | name
       | pronoun
       | computed_property

name: IDENTIFIER

pronoun: IT | THEY | THIS | THAT | THESE | THOSE

determiner: A | AN | THE



negated_property: NOT concept



property_combination: concept logical_op concept
computed_property: name APPLIED_TO arguments

// Logical expressions for constraints
logical_expr: equivalence_expr

?equivalence_expr: implication_expr ( (IFF | IS_EQUIVALENT_TO) implication_expr )*

?implication_expr: disjunction_expr ( IMPLIES disjunction_expr )*

?disjunction_expr: conjunction_expr ( OR conjunction_expr )*

?conjunction_expr: negation_expr ( AND negation_expr )*

?negation_expr: NOT negation_expr | primary_expr

?primary_expr: fact
             | LPAR logical_expr RPAR



// Terms for expressions
term: number
    | concept
    | arithmetic_expr
    | stream_term
    | property_combination

arithmetic_expr: term PLUS term
               | term MINUS term
               | term TIMES term
               | term DIVIDED_BY term
               | LPAR arithmetic_expr RPAR

// Stream terms for temporal properties
stream_term: stream_type stream_id time_reference

stream_type: INPUT | OUTPUT
stream_id: number | IDENTIFIER
time_reference: AT time_point
              | LBRACK time_expr RBRACK

time_point: TIME T | T
time_expr: T
         | T MINUS number
         | T PLUS number

// Function calls and predicates
function_call: name LPAR arguments RPAR
arguments: term (COMMA term)*

// Comparison operators
comparison_op: EQUALS | NOT_EQUALS 
             | LESS_THAN | GREATER_THAN
             | AT_MOST | AT_LEAST
             | IS | IS_NOT

// Logical operators  
logical_op: AND | OR | IMPLIES | IFF

// Basic elements

verb_phrase: name+
number: NUMBER


// Keywords (all case-insensitive)
// Temporal
ALWAYS: /always/i
EVENTUALLY: /eventually/i
SOMETIMES: /sometimes/i
NEVER: /never/i
AT_ALL_TIMES: /at\s+all\s+times/i
AT_SOME_TIME: /at\s+some\s+time/i

// Quantifiers
ALL: /all/i
EVERY: /every/i
EACH: /each/i
NO: /no/i
SOME: /some/i
EXACTLY: /exactly/i
FOR_ALL: /for\s+all/i
THERE_EXISTS: /there\s+exists/i

// Relations
IS: /is/i
ARE: /are/i
HAS: /has/i
HAVE: /have/i
MUST: /must/i
OWNS: /owns/i
CONTAINS: /contains/i
INCLUDES: /includes/i
PRECEDES: /precedes/i
FOLLOWS: /follows/i
DEPENDS_ON: /depends\s+on/i
RELATES_TO: /relates\s+to/i
SATISFIES: /satisfies/i

// Declarative keywords
HOLDS: /holds/i
IT_IS_NECESSARY_THAT: /it\s+is\s+necessary\s+that/i
CONSTRAINT: /constraint/i
IS_DEFINED_AS: /is\s+defined\s+as/i
MEANS: /means/i
IN: /in/i
IS_EQUIVALENT_TO: /is\s+equivalent\s+to/i
BY_DEFINITION: /by\s+definition/i
IS_TRUE: /is\s+true/i
SUCH_THAT: /such\s+that/i
THAT: /that/i

WHEN: /when/i
IF: /if/i
THEN: /then/i

// Properties
NOT: /not/i
POSITIVE: /positive/i
NEGATIVE: /negative/i
ZERO: /zero/i
EMPTY: /empty/i
FULL: /full/i
VALID: /valid/i
INVALID: /invalid/i

// Comparison
EQUALS: /equals/i | "="
NOT_EQUALS: /not\s+equals/i | /does\s+not\s+equal/i | "!="
LESS_THAN: /less\s+than/i | "<"
GREATER_THAN: /greater\s+than/i | ">"
AT_MOST: /at\s+most/i | "<="
AT_LEAST: /at\s+least/i | ">="
IS_NOT: /is\s+not/i

// Logical
AND: /and/i
OR: /or/i
IMPLIES: /implies/i
IFF: /iff/i | /if\s+and\s+only\s+if/i

// Arithmetic
PLUS: /plus/i | "+"
MINUS: /minus/i | "-"
TIMES: /times/i | "*"
DIVIDED_BY: /divided\s+by/i | "/"

// Stream keywords
INPUT: /input/i
OUTPUT: /output/i
AT: /at/i
TIME: /time/i
T: "t"

// Other keywords
THE: /the/i
A: /an?/i
AN: /an/i
THIS: /this/i

THESE: /these/i
THOSE: /those/i
IT: /it/i
THEY: /they/i
APPLIED_TO: /applied\s+to/i
COLON: ":"

// Basic patterns
%import common.IDENTIFIER

NUMBER: /[0-9]+(\.[0-9]+)?/

// Punctuation
PERIOD: "."
COMMA: ","
LPAR: "("
RPAR: ")"
LBRACE: "{"
RBRACE: "}"
LBRACK: "["
RBRACK: "]"

// Comments and whitespace
COMMENT: /\/\/.*/
%import common.WS
%ignore WS
%ignore COMMENT