// Common terminals for Tau grammars

SIGNED_NUMBER: /(\+|\-)?\d+(\.\d+)?/
IDENTIFIER.-1: /[a-zA-Z_][a-zA-Z0-9_]*/
ESCAPED_STRING: /\"([^\"\\]|\\.)*\"|\'([^\'\\]|\\.)*\'/ // Now supports single quotes too
WS: /[ \t\f\r\n]+/

// Optional: If you want a common DOT and import it, define it here.
// DOT: "."
